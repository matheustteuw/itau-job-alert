# Copie para .env e preencha (nunca comite o .env de verdade)

# SMTP - exemplo usando Gmail (veja README sobre "Senha de app")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app_16_digitos

# Quem aparece como remetente (geralmente igual ao SMTP_USER no Gmail)
EMAIL_FROM=seuemail@gmail.com

# Para onde mandar o alerta (pode ser o mesmo e-mail)
EMAIL_TO=seuemail@gmail.com

# --- Opcional: filtro de vagas ---
# Lista separada por vírgula. Se não definir, usa um default sensato
# (engenheiro, engenharia, java, .net, desenvolvedor, junior, pleno, senior).
# Comparação ignora acento e maiúsc/minúsc (ex: "Júnior" bate com "junior").
KEYWORDS=Engenheiro,Engenharia,Java,.NET,Desenvolvedor,Junior,Pleno,Senior

# De quanto em quanto tempo (em horas) mandar um e-mail de "status" quando
# não há vaga nova, só pra confirmar que o monitor continua rodando.
# Opcional, default 24 (uma vez por dia).
HEARTBEAT_HOURS=24

# --- Necessário só ao rodar em Lambda ---
# Bucket S3 onde fica salvo o seen_jobs.json (Lambda não tem disco persistente
# entre execuções). Sem essa variável, o programa usa um arquivo local
# (útil pra rodar/testar na sua máquina).
S3_BUCKET=
# Nome do objeto dentro do bucket (opcional, default "seen_jobs.json")
S3_KEY=
